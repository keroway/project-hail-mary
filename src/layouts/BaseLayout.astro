---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  /** ページ固有のセクション名（例「物理学編」）。トップは省略し、サイト名のみを表示。 */
  section?: string;
  description?: string;
  currentPath?: string;
}

const SITE_NAME = 'プロジェクト・ヘイルメアリー 科学入門ガイド';
/** Twitter Card の著者帰属（@ハンドル、例「@example」）。空なら帰属メタを出力しない。 */
const SITE_X_HANDLE = '';
const DEFAULT_DESCRIPTION =
  '小説「プロジェクト・ヘイルメアリー」に登場する科学的描写を中学2年生向けにやさしく解説するガイドサイト。映画鑑賞前の予習や読後の復習に最適。物理・化学・生物・数学の4教科を収録。';

const {
  section,
  description = DEFAULT_DESCRIPTION,
  currentPath = '/',
} = Astro.props;

const pageTitle = section ? `${section} | ${SITE_NAME}` : SITE_NAME;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og-image.png', Astro.site);
const ogImageAlt = 'プロジェクト・ヘイルメアリー 科学入門ガイド — 物理・化学・生物・数学の科学解説サイト';

const siteHref = Astro.site?.href ?? 'https://hailmary.keroway.com/';
const siteId = new URL('#website', siteHref).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': siteId,
      name: SITE_NAME,
      url: siteHref,
      inLanguage: 'ja',
      description: DEFAULT_DESCRIPTION,
    },
    {
      '@type': ['WebPage', 'LearningResource'],
      '@id': `${canonicalURL.href}#webpage`,
      url: canonicalURL.href,
      name: pageTitle,
      description,
      inLanguage: 'ja',
      isPartOf: { '@id': siteId },
      isAccessibleForFree: true,
      ...(section
        ? { learningResourceType: '科学解説', educationalLevel: '中学・高校', about: section }
        : {}),
    },
  ],
};

/* Custom page transition: vertical slide-up + fade */
const pageTransition = {
  forwards: {
    old: { name: 'pageSlideOut', duration: '0.25s', easing: 'ease-in', fillMode: 'both' },
    new: { name: 'pageSlideIn', duration: '0.35s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'both' },
  },
  backwards: {
    old: { name: 'pageSlideOutReverse', duration: '0.25s', easing: 'ease-in', fillMode: 'both' },
    new: { name: 'pageSlideInReverse', duration: '0.35s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'both' },
  },
};
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#03050f" />
  <meta name="color-scheme" content="dark" />
  {/* 表示設定(文字サイズ/コントラスト/動き)を描画前に先行適用し、再訪ユーザーの FOUC を防ぐ */}
  <script is:inline>
    (function () {
      try {
        var p = JSON.parse(localStorage.getItem('hailmary-ui-prefs') || '{}');
        var d = document.documentElement;
        if (p.fontScale && p.fontScale !== 'default') d.dataset.fontScale = p.fontScale;
        if (p.diagramScale && p.diagramScale !== 'default') d.dataset.diagramScale = p.diagramScale;
        if (p.contrast && p.contrast !== 'default') d.dataset.contrast = p.contrast;
        var motion;
        if (p.motion === 'reduced' && p.motionSource === 'explicit') motion = 'reduced';
        else if (p.motion === 'default') motion = 'default';
        else motion = matchMedia('(prefers-reduced-motion: reduce)').matches ? 'reduced' : 'default';
        if (motion !== 'default') d.dataset.motion = motion;
      } catch (e) {}
    })();
  </script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <meta name="twitter:card" content="summary_large_image" />
  {SITE_X_HANDLE && <meta name="twitter:site" content={SITE_X_HANDLE} />}
  {SITE_X_HANDLE && <meta name="twitter:creator" content={SITE_X_HANDLE} />}
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  <meta name="twitter:image:alt" content={ogImageAlt} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;600;700&family=Zen+Kaku+Gothic+New:wght@300;400;700&family=Space+Mono:wght@400;700&display=swap"
  />
  <title>{pageTitle}</title>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <ClientRouter />
</head>
<body data-current-path={currentPath}>
  <a href="#main-content" class="skip-link">本文へスキップ</a>

  <!-- Navigation -->
  <nav class="site-nav" transition:persist aria-label="サイト内ナビゲーション">
    <div class="nav-inner">
      <a href="/" class={`nav-home${currentPath === '/' ? ' active' : ''}`} data-nav-link aria-current={currentPath === '/' ? 'page' : undefined}>HAIL MARY</a>
      <div class="nav-links">
        <a href="/story" class={`nav-link${currentPath === '/story' ? ' active' : ''}`} data-nav-link aria-current={currentPath === '/story' ? 'page' : undefined}>ストーリー順</a>
        <a href="/physics" class={`nav-link${currentPath === '/physics' ? ' active' : ''}`} data-nav-link aria-current={currentPath === '/physics' ? 'page' : undefined}>物理</a>
        <a href="/chemistry" class={`nav-link${currentPath === '/chemistry' ? ' active' : ''}`} data-nav-link aria-current={currentPath === '/chemistry' ? 'page' : undefined}>化学</a>
        <a href="/biology" class={`nav-link${currentPath === '/biology' ? ' active' : ''}`} data-nav-link aria-current={currentPath === '/biology' ? 'page' : undefined}>生物</a>
        <a href="/math" class={`nav-link${currentPath === '/math' ? ' active' : ''}`} data-nav-link aria-current={currentPath === '/math' ? 'page' : undefined}>数学</a>
        <a href="/notes" class={`nav-link${currentPath === '/notes' ? ' active' : ''}`} data-nav-link aria-current={currentPath === '/notes' ? 'page' : undefined}>余談</a>
      </div>
      <div class="nav-status">
        <div class="nav-status-label">読了章</div>
        <div class="nav-chapter" id="nav-chapter-status"></div>
      </div>
    </div>
  </nav>
  <div class="theme-rails" aria-hidden="true"></div>

  <!-- Floating mascot -->
  <div class="scroll-mascot" aria-hidden="true" transition:persist>🚀</div>

  <!-- Page content with transition -->
  <main id="main-content" transition:animate={pageTransition}>
    <slot />
  </main>

  <div class="accessibility-tools" transition:persist>
    <button
      id="accessibility-toggle"
      class="accessibility-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="accessibility-panel"
      aria-label="表示設定を開く"
    >
      <span aria-hidden="true">Aa</span>
      <span class="sr-only">表示設定</span>
    </button>

    <section id="accessibility-panel" class="accessibility-panel" hidden aria-label="表示設定">
      <div class="accessibility-title">表示設定</div>

      <div class="accessibility-group">
        <div class="accessibility-label">文字サイズ</div>
        <div class="accessibility-options">
          <button type="button" class="accessibility-option" data-ui-setting="fontScale" data-ui-value="default">標準</button>
          <button type="button" class="accessibility-option" data-ui-setting="fontScale" data-ui-value="large">大</button>
          <button type="button" class="accessibility-option" data-ui-setting="fontScale" data-ui-value="xlarge">特大</button>
        </div>
      </div>

      <div class="accessibility-group">
        <div class="accessibility-label">図の文字</div>
        <div class="accessibility-options">
          <button type="button" class="accessibility-option" data-ui-setting="diagramScale" data-ui-value="default">標準</button>
          <button type="button" class="accessibility-option" data-ui-setting="diagramScale" data-ui-value="large">大きめ</button>
        </div>
      </div>

      <div class="accessibility-group">
        <div class="accessibility-label">コントラスト</div>
        <div class="accessibility-options">
          <button type="button" class="accessibility-option" data-ui-setting="contrast" data-ui-value="default">標準</button>
          <button type="button" class="accessibility-option" data-ui-setting="contrast" data-ui-value="high">高め</button>
        </div>
      </div>

      <div class="accessibility-group">
        <div class="accessibility-label">動き</div>
        <div class="accessibility-options">
          <button type="button" class="accessibility-option" data-ui-setting="motion" data-ui-value="default">通常</button>
          <button type="button" class="accessibility-option" data-ui-setting="motion" data-ui-value="reduced">少なめ</button>
        </div>
      </div>
    </section>
  </div>

</body>
</html>

<!-- Chapter gate script: runs on every page load / navigation -->
<script>
  import { STORAGE_KEY, readChapter, updateNavIndicator } from '../scripts/chapter';

  const UI_PREFS_KEY = 'hailmary-ui-prefs';
  const DEFAULT_UI_PREFS = {
    fontScale: 'default',
    diagramScale: 'default',
    contrast: 'default',
    motion: 'system',
    motionSource: 'system',
  };

  function readUiPrefs() {
    try {
      const raw = JSON.parse(localStorage.getItem(UI_PREFS_KEY) ?? '{}');
      return { ...DEFAULT_UI_PREFS, ...raw };
    } catch {
      return { ...DEFAULT_UI_PREFS };
    }
  }

  function writeUiPrefs(nextPrefs) {
    localStorage.setItem(UI_PREFS_KEY, JSON.stringify(nextPrefs));
  }

  function getEffectiveMotion(prefs = readUiPrefs()) {
    if (prefs.motion === 'reduced' && prefs.motionSource === 'explicit') return 'reduced';
    if (prefs.motion === 'default') return 'default';
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'reduced' : 'default';
  }

  function setDatasetValue(key, value) {
    if (value === 'default') {
      delete document.documentElement.dataset[key];
      return;
    }
    document.documentElement.dataset[key] = value;
  }

  function syncAccessibilityButtons(prefs) {
    document.querySelectorAll('[data-ui-setting][data-ui-value]').forEach((button) => {
      const setting = button.getAttribute('data-ui-setting');
      const value = button.getAttribute('data-ui-value');
      const isActive = setting === 'motion'
        ? getEffectiveMotion(prefs) === value
        : prefs[setting] === value;
      button.setAttribute('aria-pressed', String(isActive));
      button.classList.toggle('is-active', isActive);
    });
  }

  function applyUiPrefs() {
    const prefs = readUiPrefs();
    setDatasetValue('fontScale', prefs.fontScale);
    setDatasetValue('diagramScale', prefs.diagramScale);
    setDatasetValue('contrast', prefs.contrast);
    setDatasetValue('motion', getEffectiveMotion(prefs));
    syncAccessibilityButtons(prefs);
  }

  function getPanelOptionButtons() {
    const panel = document.getElementById('accessibility-panel');
    if (!panel) return [];
    return Array.from(panel.querySelectorAll<HTMLButtonElement>('[data-ui-setting][data-ui-value]'));
  }

  function closeAccessibilityPanel(restoreFocus = false) {
    const panel = document.getElementById('accessibility-panel');
    const toggle = document.getElementById('accessibility-toggle');
    if (!panel || !toggle) return;
    const wasOpen = !panel.hidden;
    panel.hidden = true;
    toggle.setAttribute('aria-expanded', 'false');
    if (restoreFocus && wasOpen) toggle.focus();
  }

  function toggleAccessibilityPanel() {
    const panel = document.getElementById('accessibility-panel');
    const toggle = document.getElementById('accessibility-toggle');
    if (!panel || !toggle) return;
    const nextOpen = panel.hidden;
    panel.hidden = !nextOpen;
    toggle.setAttribute('aria-expanded', String(nextOpen));
    // 開いたらパネル内へフォーカスを移す（WCAG 2.4.3）。Tab 循環は keydown で担保。
    if (nextOpen) getPanelOptionButtons()[0]?.focus();
  }

  /* 外部リンク(target=_blank)に「新しいタブで開く」を sr-only で予告（WCAG 3.2.5）。
     一次資料・参考リンクやネタバレ解放後のリンクにも冪等に適用する。 */
  function decorateExternalLinks() {
    document.querySelectorAll<HTMLAnchorElement>('a[target="_blank"]').forEach((a) => {
      if (a.dataset.extDecorated) return;
      a.dataset.extDecorated = 'true';
      const note = document.createElement('span');
      note.className = 'sr-only';
      note.textContent = '（新しいタブで開く）';
      a.appendChild(note);
    });
  }

  function decodeB64(str: string): string {
    const bytes = Uint8Array.from(atob(str), (c) => c.charCodeAt(0));
    return new TextDecoder().decode(bytes);
  }

  function applySpoilerGates() {
    const chapter = readChapter();
    updateNavIndicator(chapter);

    document.querySelectorAll<HTMLElement>('.spoiler-gate').forEach((gate) => {
      const min = Number.parseInt(gate.dataset.minChapter ?? '999', 10);
      const isUnlocked = chapter >= min;
      gate.classList.toggle('is-unlocked', isUnlocked);

      if (isUnlocked) {
        const contentDiv = gate.querySelector<HTMLElement>('.spoiler-gate-content');
        const template = gate.querySelector<HTMLTemplateElement>('.spoiler-gate-template');
        if (contentDiv && template && !contentDiv.dataset.loaded) {
          contentDiv.appendChild(template.content.cloneNode(true));
          contentDiv.dataset.loaded = 'true';
        }
      }
    });

    document.querySelectorAll<HTMLElement>('.timeline-item[data-min-chapter]').forEach((item) => {
      const min = Number.parseInt(item.dataset.minChapter ?? '999', 10);
      const isLocked = chapter < min;
      const originalHref = item.dataset.originalHref ?? item.getAttribute('href') ?? '';

      if (originalHref && !item.dataset.originalHref) {
        item.dataset.originalHref = originalHref;
      }

      item.classList.toggle('is-locked', isLocked);

      if (isLocked) {
        item.setAttribute('aria-disabled', 'true');
        item.setAttribute('tabindex', '-1');
        item.removeAttribute('href');
      } else {
        item.removeAttribute('aria-disabled');
        item.removeAttribute('tabindex');
        if (item.dataset.originalHref) {
          item.setAttribute('href', item.dataset.originalHref);
        }
        if (item.dataset.encodedTitle) {
          const titleEl = item.querySelector<HTMLElement>('.tl-title');
          if (titleEl && !titleEl.dataset.decoded) {
            titleEl.textContent = decodeB64(item.dataset.encodedTitle);
            titleEl.dataset.decoded = 'true';
          }
        }
        if (item.dataset.encodedMeta) {
          const metaEl = item.querySelector<HTMLElement>('.tl-meta');
          if (metaEl && !metaEl.dataset.decoded) {
            metaEl.textContent = decodeB64(item.dataset.encodedMeta);
            metaEl.dataset.decoded = 'true';
          }
        }
      }
    });

    // ネタバレ解放で差し込まれたリンクも含め、外部リンクに新規タブ予告を付ける
    decorateExternalLinks();
  }

  if (!window.__hailMaryChapterBindings) {
    window.__hailMaryChapterBindings = true;
    window.addEventListener('storage', (event) => {
      if (event.key === STORAGE_KEY || event.key === null) {
        applySpoilerGates();
      }
      if (event.key === UI_PREFS_KEY || event.key === null) {
        applyUiPrefs();
      }
    });
    document.addEventListener('chapterChanged', applySpoilerGates);
  }

  if (!window.__hailMaryUiBindings) {
    window.__hailMaryUiBindings = true;

    document.addEventListener('click', (event) => {
      const target = event.target;
      const navLink = target instanceof Element ? target.closest('[data-nav-link]') : null;
      const toggle = target instanceof Element ? target.closest('#accessibility-toggle') : null;
      const option = target instanceof Element ? target.closest('[data-ui-setting][data-ui-value]') : null;
      const tools = target instanceof Element ? target.closest('.accessibility-tools') : null;

      if (navLink instanceof HTMLElement) {
        const nav = document.querySelector('.site-nav');
        nav?.setAttribute('data-nav-loading', 'true');
        document.querySelectorAll('.site-nav .is-pressed').forEach((el) => el.classList.remove('is-pressed'));
        navLink.classList.add('is-pressed');
      }

      if (toggle) {
        toggleAccessibilityPanel();
        return;
      }

      if (option) {
        const prefs = readUiPrefs();
        const setting = option.getAttribute('data-ui-setting');
        const value = option.getAttribute('data-ui-value');
        prefs[setting] = value;
        if (setting === 'motion') {
          prefs.motionSource = 'explicit';
        }
        writeUiPrefs(prefs);
        applyUiPrefs();
        return;
      }

      if (!tools) {
        closeAccessibilityPanel();
      }
    });

    document.addEventListener('keydown', (event) => {
      const panel = document.getElementById('accessibility-panel');
      const panelOpen = !!panel && !panel.hidden;
      if (event.key === 'Escape') {
        if (panelOpen) closeAccessibilityPanel(true);
        return;
      }
      // パネルが開いている間は Tab フォーカスをパネル内に循環させる
      if (event.key === 'Tab' && panelOpen) {
        const buttons = getPanelOptionButtons();
        if (buttons.length === 0) return;
        const first = buttons[0];
        const last = buttons[buttons.length - 1];
        const active = document.activeElement;
        if (event.shiftKey) {
          if (active === first || !panel!.contains(active)) { last.focus(); event.preventDefault(); }
        } else {
          if (active === last || !panel!.contains(active)) { first.focus(); event.preventDefault(); }
        }
      }
    });
  }

  function updateActiveNav() {
    const path = '/' + window.location.pathname.replace(/^\/|\/$/g, '');
    document.querySelectorAll('[data-nav-link]').forEach((link) => {
      const href = '/' + (link.getAttribute('href') ?? '').replace(/^\/|\/$/g, '');
      const isActive = path === href;
      link.classList.toggle('active', isActive);
      if (isActive) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  /* ===== Scroll reveal via IntersectionObserver ===== */
  let scrollRevealObserver = null;
  let heroEnterObserver = null;
  let heroLeaveObserver = null;

  function hasMobileHeroMode() {
    return window.matchMedia('(max-width: 820px)').matches
      || window.matchMedia('(hover: none)').matches
      || window.matchMedia('(any-hover: none)').matches
      || window.matchMedia('(pointer: coarse)').matches
      || navigator.maxTouchPoints > 0;
  }

  function syncMobileHeroMode() {
    const enabled = hasMobileHeroMode();
    if (enabled) {
      document.documentElement.dataset.mobileHero = 'enabled';
    } else {
      delete document.documentElement.dataset.mobileHero;
    }
    return enabled;
  }

  function initScrollReveal() {
    if (scrollRevealObserver) scrollRevealObserver.disconnect();
    if (heroEnterObserver) heroEnterObserver.disconnect();
    if (heroLeaveObserver) heroLeaveObserver.disconnect();

    const mobileHeroMode = syncMobileHeroMode();
    const isReduced = document.documentElement.dataset.motion === 'reduced';
    const heroImages = document.querySelectorAll('.phase-hero');

    const targets = document.querySelectorAll(
      '.phase, .intro, .chapter-selector, .subject-card, .timeline-item'
    );

    scrollRevealObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            scrollRevealObserver.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.08, rootMargin: '0px 0px -32px 0px' }
    );

    for (const el of targets) {
      el.classList.add('scroll-reveal');
      scrollRevealObserver.observe(el);
    }

    for (const img of heroImages) {
      img.classList.remove('is-in-view', 'hero-revealed', 'hero-heading-zone');
    }

    if (!mobileHeroMode || isReduced) return;

    /* ヒステリシス付き2状態: 入域は厳しめ・退域はゆるめの rootMargin で切替を安定させる */
    const heroState = new WeakMap();
    let rafPending = null;
    const pendingOps = new Map();

    function flushHeroState() {
      rafPending = null;
      for (const [el, next] of pendingOps) {
        if (heroState.get(el) === next) continue;
        heroState.set(el, next);
        el.classList.toggle('is-in-view', next === 'in');
      }
      pendingOps.clear();
    }

    function scheduleHeroUpdate(el, next) {
      pendingOps.set(el, next);
      if (rafPending == null) rafPending = requestAnimationFrame(flushHeroState);
    }

    heroEnterObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) scheduleHeroUpdate(entry.target, 'in');
        }
      },
      { rootMargin: '-20% 0px -50% 0px', threshold: 0 }
    );

    heroLeaveObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) scheduleHeroUpdate(entry.target, 'out');
        }
      },
      { rootMargin: '0% 0px -70% 0px', threshold: 0 }
    );

    for (const img of heroImages) {
      heroEnterObserver.observe(img);
      heroLeaveObserver.observe(img);
    }
  }

  /* ===== Floating mascot scroll effect ===== */
  let mascotRafId = null;

  function initScrollMascot() {
    if (mascotRafId) { cancelAnimationFrame(mascotRafId); mascotRafId = null; }

    const mascot = document.querySelector<HTMLElement>('.scroll-mascot');
    if (!mascot) return;

    const isReduced = document.documentElement.dataset.motion === 'reduced';
    if (isReduced) { mascot.classList.remove('is-active'); return; }

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      mascotRafId = requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        const progress = maxScroll > 0 ? Math.min(scrollY / maxScroll, 1) : 0;

        /* Show after scrolling a bit */
        if (scrollY > 120) {
          mascot.classList.add('is-active');
        } else {
          mascot.classList.remove('is-active');
        }

        /* Move upward as user scrolls (like launching) */
        const yOffset = -(progress * 50);
        mascot.style.setProperty('--mascot-scroll', `${yOffset}px`);
        ticking = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const handleReducedMotionChange = () => {
    if (readUiPrefs().motion !== 'system') return;
    applyUiPrefs();
    initScrollReveal();
    initScrollMascot();
  };
  let lastMobileHeroMode = syncMobileHeroMode();
  let resizeRafId = null;
  const handleViewportChange = () => {
    if (resizeRafId) cancelAnimationFrame(resizeRafId);
    resizeRafId = requestAnimationFrame(() => {
      const nextMobileHeroMode = syncMobileHeroMode();
      if (nextMobileHeroMode !== lastMobileHeroMode) {
        lastMobileHeroMode = nextMobileHeroMode;
        initScrollReveal();
      }
      resizeRafId = null;
    });
  };
  if (typeof prefersReducedMotion.addEventListener === 'function') {
    prefersReducedMotion.addEventListener('change', handleReducedMotionChange);
  } else if (typeof prefersReducedMotion.addListener === 'function') {
    prefersReducedMotion.addListener(handleReducedMotionChange);
  }
  window.addEventListener('resize', handleViewportChange, { passive: true });

  applySpoilerGates();
  applyUiPrefs();
  updateActiveNav();
  initScrollReveal();
  initScrollMascot();
  document.addEventListener('astro:page-load', () => {
    document.querySelector('.site-nav')?.removeAttribute('data-nav-loading');
    document.querySelectorAll('.site-nav .is-pressed').forEach((el) => el.classList.remove('is-pressed'));
    updateActiveNav();
    applySpoilerGates();
    applyUiPrefs();
    closeAccessibilityPanel();
    initScrollReveal();
    initScrollMascot();
  });
</script>
