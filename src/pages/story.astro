---
import BaseLayout from '../layouts/BaseLayout.astro';
const enc = (s: string) => Buffer.from(s, 'utf-8').toString('base64');
---
<BaseLayout title="ストーリー順 — ヘイルメアリー サイエンスガイド" currentPath="/story">

<div class="container">

  <header>
    <div class="header-eyebrow">STORY ORDER</div>
    <h1>ストーリー順に読む</h1>
    <p class="header-sub">物語の進行に合わせて、登場する科学を学ぶ</p>
  </header>

  <div class="intro">
    <p>このページでは、小説の展開順に科学トピックを並べています。<strong>読了章の設定に合わせてネタバレ部分は自動でロック</strong>されます。各項目をクリックすると、詳細ページに移動します。</p>
  </div>

  <!-- ACT 1 -->
  <div class="act">
    <div class="act-header">
      <span class="act-num">ACT 1</span>
      <h2 class="act-title">目覚め——宇宙船での一人</h2>
      <span class="act-range">第1〜3章あたり</span>
    </div>

    <div class="story-timeline">
      <a class="timeline-item" href="/physics#phase01">
        <div class="tl-seq">01</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#4a9eff;">PHYSICS · PHASE 01</div>
          <div class="tl-title">目覚め・無重力の謎</div>
          <div class="tl-meta">万有引力 / 軌道運動 / 自由落下</div>
        </div>
      </a>

      <a class="timeline-item" href="/biology#bio02">
        <div class="tl-seq">02</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#34d399;">BIOLOGY · BIO 02</div>
          <div class="tl-title">医学的誘発昏睡——グレースが眠った理由</div>
          <div class="tl-meta">神経科学 / 麻酔・昏睡 / 冬眠の科学</div>
        </div>
      </a>

      <a class="timeline-item" href="/physics#phase02">
        <div class="tl-seq">03</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#4a9eff;">PHYSICS · PHASE 02</div>
          <div class="tl-title">振り子で重力を測る</div>
          <div class="tl-meta">単振動 / 重力加速度 / 周期と長さの関係</div>
        </div>
      </a>

      <a class="timeline-item" href="/physics#phase03">
        <div class="tl-seq">04</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#4a9eff;">PHYSICS · PHASE 03</div>
          <div class="tl-title">人工重力と遠心力</div>
          <div class="tl-meta">慣性 / 遠心力 / 非慣性系</div>
        </div>
      </a>
    </div>
  </div>

  <!-- ACT 2 -->
  <div class="act">
    <div class="act-header">
      <span class="act-num">ACT 2</span>
      <h2 class="act-title">アストロファージとの格闘</h2>
      <span class="act-range">第3〜8章あたり</span>
    </div>

    <div class="story-timeline">
      <a class="timeline-item" href="/physics#phase04">
        <div class="tl-seq">05</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#4a9eff;">PHYSICS · PHASE 04</div>
          <div class="tl-title">アストロファージ — エネルギーを食べる生命</div>
          <div class="tl-meta">エネルギー保存則 / 核融合 / 光のエネルギー</div>
        </div>
      </a>

      <a class="timeline-item" href="/biology#bio01">
        <div class="tl-seq">06</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#34d399;">BIOLOGY · BIO 01</div>
          <div class="tl-title">アストロファージの細胞生物学</div>
          <div class="tl-meta">光合成 / 細胞構造 / 極限環境生物</div>
        </div>
      </a>

      <a class="timeline-item" href="/biology#bio04">
        <div class="tl-seq">07</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#34d399;">BIOLOGY · BIO 04</div>
          <div class="tl-title">極限環境生物——「ありえない場所」に生きる生命</div>
          <div class="tl-meta">extremophile / 熱水噴出孔 / 宇宙生物学</div>
        </div>
      </a>

      <a class="timeline-item" href="/chemistry#chem01">
        <div class="tl-seq">08</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#a78bfa;">CHEMISTRY · CHEM 01</div>
          <div class="tl-title">アストロファージの元素組成</div>
          <div class="tl-meta">元素 / 有機化合物 / CHNOPS の法則</div>
        </div>
      </a>

      <a class="timeline-item" href="/chemistry#chem02">
        <div class="tl-seq">09</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#a78bfa;">CHEMISTRY · CHEM 02</div>
          <div class="tl-title">ペトロヴァ周波数——アストロファージが放つ光</div>
          <div class="tl-meta">赤外線分光 / 電磁波 / 光のエネルギーと波長</div>
        </div>
      </a>

      <a class="timeline-item" href="/physics#phase07">
        <div class="tl-seq">10</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#4a9eff;">PHYSICS · PHASE 07</div>
          <div class="tl-title">光の圧力とソーラーセイル——光子が持つ「力」</div>
          <div class="tl-meta">光子の運動量 / 光圧 / 電磁放射圧</div>
        </div>
      </a>

      <a class="timeline-item" href="/chemistry#chem03">
        <div class="tl-seq">11</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#a78bfa;">CHEMISTRY · CHEM 03</div>
          <div class="tl-title">宇宙船の空気管理——気体の化学</div>
          <div class="tl-meta">気体の法則 / 酸素・二酸化炭素 / 生命維持システム</div>
        </div>
      </a>

      <a class="timeline-item" href="/math#math02">
        <div class="tl-seq">12</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#f59e0b;">MATH · MATH 02</div>
          <div class="tl-title">対数スケール——宇宙的な数を扱う道具</div>
          <div class="tl-meta">対数 / 指数関数 / 天文学的スケール</div>
        </div>
      </a>

      <a class="timeline-item" href="/math#math04">
        <div class="tl-seq">13</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#f59e0b;">MATH · MATH 04</div>
          <div class="tl-title">指数関数——アストロファージが世界を脅かす理由</div>
          <div class="tl-meta">指数関数 / 倍増時間 / 指数的増殖</div>
        </div>
      </a>

      <a class="timeline-item" href="/math#math03">
        <div class="tl-seq">14</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#f59e0b;">MATH · MATH 03</div>
          <div class="tl-title">軌道計算とホーマン遷移</div>
          <div class="tl-meta">微積分 / ケプラーの法則 / 最適経路問題</div>
        </div>
      </a>
    </div>
  </div>

  <!-- ACT 3 — spoiler ch9 -->
  <div class="act" id="act3">
    <div class="act-header act-header--spoiler">
      <span class="act-num">ACT 3</span>
      <h2 class="act-title">ロッキーとの出会い</h2>
      <span class="act-range" id="act3-range">第9章以降</span>
    </div>

    <div class="story-timeline">
      <a class="timeline-item" href="/math#math01" data-min-chapter="9"
         data-encoded-title={enc('素数——最初の共通言語')}
         data-encoded-meta={enc('素数 / 整数論 / 数学の普遍性')}>
        <div class="tl-seq">15</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#f59e0b;">MATH · MATH 01</div>
          <div class="tl-title">???</div>
          <div class="tl-meta">第9章以降に解放</div>
        </div>
        <div class="tl-lock">🔒</div>
      </a>

      <a class="timeline-item" href="/physics#phase05" data-min-chapter="9"
         data-encoded-title={enc('ロッキーとの会話 — 音波と周波数')}
         data-encoded-meta={enc('波 / 周波数 / 音の情報伝達')}>
        <div class="tl-seq">16</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#4a9eff;">PHYSICS · PHASE 05</div>
          <div class="tl-title">???</div>
          <div class="tl-meta">第9章以降に解放</div>
        </div>
        <div class="tl-lock">🔒</div>
      </a>

      <a class="timeline-item" href="/biology#bio03" data-min-chapter="9"
         data-encoded-title={enc('収斂進化——異なる道をたどって同じ形に至る')}
         data-encoded-meta={enc('進化論 / 収斂進化 / 知性の普遍性')}>
        <div class="tl-seq">17</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#34d399;">BIOLOGY · BIO 03</div>
          <div class="tl-title">???</div>
          <div class="tl-meta">第9章以降に解放</div>
        </div>
        <div class="tl-lock">🔒</div>
      </a>
    </div>
  </div>

  <!-- ACT 4 — spoiler ch25 -->
  <div class="act">
    <div class="act-header act-header--spoiler">
      <span class="act-num">ACT 4</span>
      <h2 class="act-title">終盤の決断</h2>
      <span class="act-range">第25章以降</span>
    </div>

    <div class="story-timeline">
      <a class="timeline-item" href="/physics#phase06" data-min-chapter="25"
         data-encoded-title={enc('宇宙旅行と相対性理論')}
         data-encoded-meta={enc('特殊相対性理論 / 時間の遅れ / 光速と質量')}>
        <div class="tl-seq">18</div>
        <div class="tl-body">
          <div class="tl-code" style="color:#4a9eff;">PHYSICS · PHASE 06</div>
          <div class="tl-title">???</div>
          <div class="tl-meta">第25章以降に解放</div>
        </div>
        <div class="tl-lock">🔒</div>
      </a>
    </div>
  </div>

  <div class="section-divider"><span class="divider-label">— END —</span></div>

  <div style="text-align: center; margin-bottom: 80px;">
    <p style="font-size: 13px; color: var(--dim-star); margin-bottom: 20px;">
      読了章を変更したい場合はトップページへ
    </p>
    <a href="/" class="btn">← トップに戻る</a>
  </div>

</div>
</BaseLayout>

<style>
  :root {
    --accent:        #00d4aa;
    --accent-glow:   rgba(0, 212, 170, 0.3);
    --accent-bg:     rgba(0, 212, 170, 0.08);
    --accent-border: rgba(0, 212, 170, 0.2);
    --star-tint-a:   rgba(74, 158, 255, 0.3);
    --star-tint-b:   rgba(0, 212, 170, 0.3);
  }

  .act { margin-bottom: 48px; }

  .act-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    flex-wrap: wrap;
  }

  .act-num {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--aurora);
    background: rgba(0, 212, 170, 0.08);
    border: 1px solid rgba(0, 212, 170, 0.2);
    padding: 3px 10px;
    flex-shrink: 0;
  }

  .act-title {
    font-family: 'Shippori Mincho', serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--white-star);
    margin: 0;
  }

  .act-range {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--dim-star);
    margin-left: auto;
  }

  .act-header--spoiler .act-num {
    color: var(--red-dwarf);
    background: rgba(255, 107, 107, 0.08);
    border-color: rgba(255, 107, 107, 0.2);
  }
  .act-header--spoiler .act-range {
    color: var(--red-dwarf);
    opacity: 0.7;
  }
</style>
